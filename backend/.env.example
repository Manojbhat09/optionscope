# Copy this file to .env and fill in your API keys

# Anthropic Claude (claude-opus-4-8) - recommended
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI GPT-4o
OPENAI_API_KEY=sk-...

# OpenRouter (free Llama model fallback)
REACT_APP_OPENROUTER_API_KEY=sk-or-...

# ── Stock history providers (for 1h data older than 730 days) ──────────────────
# Alpaca Markets — free paper account at alpaca.markets, gives 1h back to 2016 via IEX
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# Polygon.io — free key at polygon.io, covers ~2 years of 1h history
POLYGON_API_KEY=
